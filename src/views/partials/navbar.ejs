<nav class="navbar">
    <div class="nav-left">
        <% if (currentUser) { 
            const name = currentUser.name || currentUser.username || 'User';
            const initials = name.trim().split(/\s+/).map(p => p[0]).join('').slice(0,2).toUpperCase();
        %>
            <a href="/profile" class="nav-avatar-link">
                <div class="nav-avatar"><%= initials %></div>
            </a>
            <a href="/profile" class="nav-hello">Hi, <%= name %></a>
        <% } else { %>
            <div class="logo">Virtual Interview Simulator</div>
        <% } %>
    </div>
    <div class="nav-links">
        <% if (currentUser) { %>
            <% if (activePath !== '/') { %><a href="/" class="btn-outline">Home</a><% } %>
            <% if (activePath !== '/resumes') { %><a href="/resumes" class="btn-outline">Resumes</a><% } %>
            <% if (activePath !== '/openai/logs') { %><a href="/openai/logs" class="btn-outline">Chat Logs</a><% } %>
            <% if (activePath !== '/profile') { %><a href="/profile" class="btn-outline">Profile</a><% } %>
            <% if (activePath !== '/upload') { %><a href="/upload" class="btn-outline">Upload</a><% } %>
            <% if (activePath !== '/openai') { %><a href="/openai" class="btn-primary">AI-Powered Mock Interviewer</a><% } %>
        <% } else { %>
            <% if (activePath !== '/') { %><a href="/" class="btn-outline">Home</a><% } %>
            <% if (activePath !== '/login') { %><a href="/login" class="btn-outline">Login</a><% } %>
            <% if (activePath !== '/signup') { %><a href="/signup" class="btn-primary">Sign Up</a><% } %>
        <% } %>
    </div>
</nav>
