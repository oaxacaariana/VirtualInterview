<!DOCTYPE html>
<html>
<head>
    <title>Chat Logs | Virtual Interview</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0' x2='1' y1='0' y2='1'%3E%3Cstop stop-color='%233a7bfd'/%3E%3Cstop offset='1' stop-color='%236b5bff'/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect width='64' height='64' rx='14' fill='%230f0f10'/%3E%3Cpath d='M18 42l10-20 8 12 10-8' stroke='url(%23g)' stroke-width='5' fill='none' stroke-linecap='round' stroke-linejoin='round'/%3E%3Ccircle cx='48' cy='18' r='4' fill='%236b5bff'/%3E%3C/svg%3E">
    <link rel="stylesheet" href="/styles/app.css">
</head>
<body>
<%- include('partials/navbar'); %>

<div class="pg-hero">
    <div class="pg-orb pg-orb--purple"></div>
    <div class="section-shell pg-hero__inner">
        <div>
            <p class="eyebrow">Interview archive</p>
            <h1 class="pg-hero__title">Chat logs</h1>
            <p class="pg-hero__sub">Recent mock interviews with saved setup, grades, and completion status.</p>
        </div>
        <div class="hero-cta-row">
            <a href="/openai" class="btn-primary lp-btn-glow">New interview</a>
        </div>
    </div>
</div>

<section class="pg-body">
    <div class="section-shell">
        <% if (chats && chats.length) { %>
            <div class="resumes-grid chat-logs-grid">
                <% chats.forEach(chat => { %>
                    <%
                        const rawRoleTitle = chat.context?.role || 'Interview';
                        const displayRoleTitle = rawRoleTitle.length > 44
                          ? `${rawRoleTitle.slice(0, 41)}...`
                          : rawRoleTitle;
                        const rawScore = chat.finalScore?.overallScore;
                        const score = Number.isFinite(Number(rawScore)) ? Number(rawScore) : null;
                        const ringScore = score !== null ? (score * 3.6) + 'deg' : '0deg';
                        const ringColor = score === null ? '#555'
                            : score >= 80 ? '#2dd4bf'
                            : score >= 65 ? '#60a5fa'
                            : score >= 50 ? '#f0a202'
                            : '#f65f5f';
                        const storedGradeLetter = ((chat.finalScore?.grade || '').toString().trim().charAt(0) || '').toUpperCase();
                        const derivedGradeLetter = score === null ? 'P'
                            : score >= 85 ? 'A' : score >= 70 ? 'B' : score >= 50 ? 'C' : score >= 35 ? 'D' : 'F';
                        const gradeLetter = ['A','B','C','D','F'].includes(storedGradeLetter) ? storedGradeLetter : derivedGradeLetter;
                        const gradeClass = gradeLetter === 'A' ? 'grade-a'
                            : gradeLetter === 'B' ? 'grade-b'
                            : gradeLetter === 'C' ? 'grade-c'
                            : gradeLetter === 'D' ? 'grade-d'
                            : gradeLetter === 'F' ? 'grade-f'
                            : 'grade-pending';
                    %>
                    <a href="/openai/logs/<%= chat.chatId %>" class="resume-card glass chat-log-card-link chat-grade-card <%= gradeClass %>">
                        <div class="chat-grade-card__letter"><%= gradeLetter %></div>
                        <div class="resume-card__top">
                            <div class="resume-card__meta">
                                <h3 class="resume-title" title="<%= rawRoleTitle %>"><%= displayRoleTitle %></h3>
                                <p class="muted" style="margin-top:4px;">Company: <%= chat.context?.company || 'Not set' %></p>
                                <div class="pill-row" style="margin-top:10px;">
                                    <span class="pill">Status: <%= chat.status || 'unknown' %></span>
                                    <span class="pill">Updated: <%= chat.updatedAt ? new Date(chat.updatedAt).toISOString().slice(0,16).replace('T',' ') : 'n/a' %></span>
                                    <span class="pill">Length: <%= chat.interviewLength || 'n/a' %></span>
                                    <span class="pill">Mode: <%= chat.context?.modeLabel || (chat.context?.silly ? 'Crazy Mode' : 'Operating Mode') %></span>
                                    <span class="pill">Persona: <%= chat.context?.personaLabel || 'Legacy interviewer' %></span>
                                </div>
                            </div>
                            <div class="score-ring profile-ring score-ring-lg" style="--score:<%= ringScore %>; --ring-color:<%= ringColor %>; flex-shrink:0;">
                                <div class="score-ring__fill"></div>
                                <div class="score-ring__center"><%= score === null ? '-' : score %></div>
                            </div>
                        </div>
                    </a>
                <% }) %>
            </div>
        <% } else { %>
            <div class="pg-empty">
                <p class="eyebrow">Nothing here yet</p>
                <h3>No chat logs yet</h3>
                <p>Start a mock interview and complete a session to see it archived here.</p>
                <a href="/openai" class="btn-primary lp-btn-glow">Start interview</a>
            </div>
        <% } %>
    </div>
</section>

<%- include('partials/footer'); %>
</body>
</html>
