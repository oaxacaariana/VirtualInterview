<!DOCTYPE html>
<html>
<head>
    <title>AI-Powered Mock Interviewer | Virtual Interview Simulator</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0' x2='1' y1='0' y2='1'%3E%3Cstop stop-color='%233a7bfd'/%3E%3Cstop offset='1' stop-color='%236b5bff'/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect width='64' height='64' rx='14' fill='%230f0f10'/%3E%3Cpath d='M18 42l10-20 8 12 10-8' stroke='url(%23g)' stroke-width='5' fill='none' stroke-linecap='round' stroke-linejoin='round'/%3E%3Ccircle cx='48' cy='18' r='4' fill='%236b5bff'/%3E%3C/svg%3E">
    <link rel="stylesheet" href="/styles/app.css">
    <script type="module" src="https://unpkg.com/@dotlottie/player-component@latest/dist/dotlottie-player.mjs"></script>
    <script src="/scripts/eye-tracking/webgazer.js" type="text/javascript"></script>
    <script src="/scripts/eye-tracking/face-api.min.js"></script>
</head>
<body>
    <% const safeInterviewConfig = typeof interviewConfig === 'undefined' ? {} : interviewConfig; %>
    <%- include('partials/navbar'); %>
    <script id="interview-config" type="application/json"><%- JSON.stringify(safeInterviewConfig) %></script>
    <script>
        const interviewConfigNode = document.getElementById('interview-config');
        window.__INTERVIEW_CONFIG__ = interviewConfigNode
            ? JSON.parse(interviewConfigNode.textContent || '{}')
            : {};
    </script>

    <div class="iv-shell">
        <div class="iv-stage">
            <div class="iv-aria-bg" id="avatar-container">
                <!-- Lottie avatar -->
                <div class="av-lottie-wrap">
                    <dotlottie-player
                        id="aria-lottie"
                        src="https://lottie.host/faee22c4-f7e3-4d8f-a9d2-96a7954db3e7/6EFlWLrPFI.lottie"
                        background="transparent"
                        speed="1"
                        loop
                        autoplay>
                    </dotlottie-player>
                </div>

                <div class="iv-aria-nametag">
                    <span class="iv-aria-name" id="iv-interviewer-name">Dorian</span>
                    <span class="stage-badge" id="iv-interviewer-badge">Skeptical Manager</span>
                </div>

                <div class="av-talk-ring"></div>
                <div id="eye-tracking-spot" aria-hidden="true"></div>
            </div>

            <div class="iv-pip">
                <video id="camera-feed" autoplay playsinline muted></video>
                <div id="camera-placeholder" class="camera-placeholder hidden">
                    <svg viewBox="0 0 64 64" width="36" height="36">
                        <circle cx="32" cy="26" r="11" fill="none" stroke="#3a5a7a" stroke-width="2"/>
                        <path d="M12 56 C12 40 20 34 32 32 C44 34 52 40 52 56" fill="none" stroke="#3a5a7a" stroke-width="2"/>
                    </svg>
                    <p style="font-size:0.75rem; color:#4a6a8a; margin-top:4px;">Camera off</p>
                </div>
                <div class="cam-corners">
                    <span class="cc cc-tl"></span>
                    <span class="cc cc-tr"></span>
                    <span class="cc cc-bl"></span>
                    <span class="cc cc-br"></span>
                </div>
                <div class="iv-pip-label">
                    <span class="iv-pip-name">You</span>
                    <span class="stage-live" id="stage-live-badge"></span>
                </div>
            </div>

            <div class="iv-topbar">
                <div class="iv-topbar-left">
                    <span id="ai-status" class="status-dot">Ready</span>
                </div>
                <div class="iv-topbar-center">
                    <p class="eyebrow" style="color:#4a7aaa; font-size:0.7rem; letter-spacing:0.1em; margin:0 0 1px;">Simulated interview</p>
                    <span style="font-weight:600; color:#dbeafe; font-size:0.88rem;">AI-Powered Mock Interviewer</span>
                </div>
                <div class="iv-topbar-right">
                    <button type="button" id="setup-btn" class="iv-toolbar-btn">Setup</button>
                    <a href="/openai/logs" class="iv-toolbar-btn">Logs</a>
                    <button type="button" id="context-btn" class="iv-toolbar-btn iv-toolbar-btn-primary">New chat</button>
                </div>
            </div>

            <div class="iv-subtitles-bar">
                <p id="iv-subtitle-text" class="iv-subtitle-text"></p>
            </div>

            <div id="interview-complete-banner" class="iv-complete-banner hidden" aria-live="polite">
                <p class="eyebrow">Interview finished</p>
                <h3>Final breakdown ready</h3>
                <p>Your practice session is closed. Review the final score, inspect the chat history, or start a new interview.</p>
                <div class="iv-complete-actions">
                    <a href="/openai/logs" class="btn-outline">View chat history</a>
                    <button type="button" id="interview-complete-new-chat" class="btn-primary">Start new chat</button>
                </div>
            </div>

            <div id="interview-boot-overlay" class="iv-boot-overlay hidden" aria-live="polite" aria-hidden="true">
                <div class="iv-boot-card">
                    <div class="iv-boot-spinner" aria-hidden="true"></div>
                    <p class="eyebrow">Preparing interview</p>
                    <h3 id="interview-boot-title">Building your first prompt</h3>
                    <p id="interview-boot-text">We are reading your resume, pulling company context, and shaping Aria's background so the opener feels researched instead of generic.</p>
                    <div class="iv-boot-steps" aria-hidden="true">
                        <span>Resume context</span>
                        <span>Company research</span>
                        <span>Interviewer background</span>
                    </div>
                </div>
            </div>

            <div id="eye-calibration-overlay" class="eye-calibration-overlay hidden" aria-hidden="true">
                <div class="eye-calibration-copy">
                    <p class="eyebrow">Eye calibration</p>
                    <h3>Click each point while looking directly at it</h3>
                    <p>Use this to improve tracking drift. Each point needs 5 clicks before it locks in.</p>
                    <div class="eye-calibration-actions">
                        <button type="button" id="eye-calibration-cancel" class="btn-outline">Cancel</button>
                    </div>
                </div>
                <div class="eye-calibration-surface" aria-hidden="true">
                    <button type="button" class="eye-calibration-point" data-point="1">1</button>
                    <button type="button" class="eye-calibration-point" data-point="2">2</button>
                    <button type="button" class="eye-calibration-point" data-point="3">3</button>
                    <button type="button" class="eye-calibration-point" data-point="4">4</button>
                    <button type="button" class="eye-calibration-point" data-point="5">5</button>
                    <button type="button" class="eye-calibration-point" data-point="6">6</button>
                    <button type="button" class="eye-calibration-point" data-point="7">7</button>
                    <button type="button" class="eye-calibration-point" data-point="8">8</button>
                    <button type="button" class="eye-calibration-point" data-point="9">9</button>
                </div>
            </div>

            <aside class="iv-side-panel" id="iv-chat-panel" aria-hidden="true">
                <div class="iv-panel-head">
                    <div>
                        <p class="eyebrow" style="margin-bottom:2px;">Transcript</p>
                        <h3 style="margin:0; font-size:1.05rem;">Chat history</h3>
                    </div>
                    <button class="iv-panel-close" id="iv-chat-close" aria-label="Close">X</button>
                </div>
                <div id="chat-log" class="chat-log" style="min-height:120px; flex:1; overflow-y:auto; max-height:none;"></div>
            </aside>

            <aside class="iv-side-panel iv-coach-side" id="iv-coach-panel" aria-hidden="true">
                <div class="iv-panel-head iv-panel-head--coach">
                    <div>
                        <p class="eyebrow" style="margin-bottom:2px;">Response coach</p>
                        <h3 style="margin:0; font-size:1.05rem;">Live read</h3>
                    </div>
                    <div style="display:flex; gap:8px; align-items:center;">
                        <button type="button" id="analysis-privacy-btn" class="pill-btn" style="font-size:0.75rem; padding:4px 10px;">Blur coach</button>
                        <span class="review-badge">Live</span>
                        <button class="iv-panel-close" id="iv-coach-close" aria-label="Close">X</button>
                    </div>
                </div>
                <div class="iv-panel-scroll">
                    <div class="coach-tabs" role="tablist" aria-label="Coach views">
                        <button type="button" id="coach-tab-live" class="coach-tab is-active" role="tab" aria-selected="true" aria-controls="coach-tabpanel-live">Live coach</button>
                        <button type="button" id="coach-tab-final" class="coach-tab" role="tab" aria-selected="false" aria-controls="coach-tabpanel-final">Final breakdown</button>
                    </div>

                    <div id="coach-tabpanel-live" class="coach-tab-panel is-active" role="tabpanel" aria-labelledby="coach-tab-live">
                        <div id="live-engagement-panel" class="engagement-panel"></div>
                        <div id="analysis-panel" class="analysis-panel" style="min-height:120px;"></div>
                    </div>

                    <div id="coach-tabpanel-final" class="coach-tab-panel" role="tabpanel" aria-labelledby="coach-tab-final">
                        <div id="final-engagement-panel" class="engagement-panel"></div>
                        <div id="final-score-panel" class="final-score-panel"></div>
                    </div>
                </div>
            </aside>
        </div>

        <div class="iv-controls-bar">
            <div class="iv-ctrl-left">
                <button type="button" id="mic-btn" class="btn-primary outline">Voice</button>
                <button type="button" id="iv-toggle-mute" class="iv-icon-btn is-active" title="Mute Aria">
                    <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" width="15" height="15" aria-hidden="true">
                        <path d="M3 7h3l4-4v14l-4-4H3V7z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                        <path d="M14 7a4 4 0 0 1 0 6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                        <line class="mute-slash" x1="2" y1="18" x2="18" y2="2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" style="display:none"/>
                    </svg>
                    Audio
                </button>
                <span class="iv-audio-note">AI voice</span>
                <button type="button" id="iv-toggle-camera" class="iv-icon-btn is-active" title="Turn camera off">
                    <svg class="cam-btn-icon" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" width="15" height="15" aria-hidden="true">
                        <rect x="1" y="5" width="12" height="10" rx="2" stroke="currentColor" stroke-width="1.7"/>
                        <path d="M13 9l5-3v8l-5-3V9z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                        <line class="cam-off-slash" x1="2" y1="18" x2="18" y2="2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                    </svg>
                    Camera
                </button>
                <button type="button" id="iv-recalibrate" class="iv-icon-btn" title="Calibrate eye tracking">
                    <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" width="15" height="15" aria-hidden="true">
                        <circle cx="10" cy="10" r="6.5" stroke="currentColor" stroke-width="1.7"/>
                        <circle cx="10" cy="10" r="1.4" fill="currentColor"/>
                        <path d="M10 1.8v2.1M10 16.1v2.1M18.2 10h-2.1M3.9 10H1.8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    Calibrate
                </button>
                <span id="mic-status" class="muted" style="font-size:0.82rem;"></span>
            </div>

            <form id="ai-form" class="iv-input-form">
                <textarea id="prompt" name="prompt" rows="2" maxlength="4000" placeholder="Type your answer or ask for clarification..."></textarea>
                <button type="submit" id="send-btn" class="btn-primary">Send</button>
            </form>

            <div class="iv-ctrl-right">
                <button type="button" id="iv-toggle-chat" class="iv-icon-btn" title="Toggle transcript">
                    <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" width="15" height="15" aria-hidden="true">
                        <path d="M2 5h16M2 10h10M2 15h7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                    Chat
                </button>
                <button type="button" id="iv-toggle-coach" class="iv-icon-btn iv-icon-btn-coach" title="Toggle coach">
                    <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" width="15" height="15" aria-hidden="true">
                        <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.8"/>
                        <path d="M10 7v4M10 14.5v.1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                    Coach
                    <span class="iv-btn-badge">Key</span>
                </button>
                <button type="button" id="end-btn" class="btn-danger" style="padding:8px 16px; color:#fff;">End</button>
            </div>
        </div>
    </div>

    <div id="context-modal" class="modal hidden">
        <div class="modal-card modal-card-lg">
            <div class="modal-head">
                <div>
                    <p class="eyebrow">Interview setup</p>
                    <h3 id="context-modal-title">Create new chat</h3>
                    <p id="context-modal-subtitle" class="muted">Choose the resume, tune the interviewer, and launch.</p>
                    <p id="context-modal-feedback" class="context-modal-feedback hidden" role="alert"></p>
                </div>
                <button id="close-modal" class="btn-primary modal-close-btn">Close</button>
            </div>
            <form id="context-form">
                <div class="setup-grid">
                    <div class="setup-column">
                        <div class="setup-card">
                            <label>Target company</label>
                            <input type="text" id="ctx-company" maxlength="200" placeholder="Company name">

                            <label>Target role / title</label>
                            <input type="text" id="ctx-role" maxlength="200" placeholder="e.g., Senior Backend Engineer">

                            <div class="setup-card setup-card-subtle">
                                <div class="setup-card__head">
                                    <div>
                                        <p class="eyebrow">Interview mode</p>
                                        <h4>Choose how the interviewer behaves</h4>
                                    </div>
                                </div>
                                <div class="mode-card-grid">
                                    <label class="mode-card">
                                        <input type="radio" name="ctx-mode" id="ctx-mode-operating" value="operating" checked>
                                        <span class="mode-card__title">Operating mode</span>
                                        <span class="mode-card__copy">Maximum scrutiny, hardest grading, and no buzzword leniency.</span>
                                    </label>
                                    <label class="mode-card">
                                        <input type="radio" name="ctx-mode" id="ctx-mode-crazy" value="crazy">
                                        <span class="mode-card__title">Crazy mode</span>
                                        <span class="mode-card__copy">Experimental and playful. Sliders and custom tone unlock here.</span>
                                    </label>
                                </div>
                            </div>

                            <div class="setup-switches">
                                <label class="switch-row">
                                    <span>
                                        <strong>Web research</strong>
                                        <small class="muted">Pull external context before the interview starts.</small>
                                    </span>
                                    <span class="switch">
                                        <input type="checkbox" id="ctx-web-search" checked>
                                        <span class="switch-ui"></span>
                                    </span>
                                </label>
                            </div>

                            <div id="operating-mode-block" class="setup-note-card">
                                <p class="eyebrow">Operating mode locks</p>
                                <h4>High scrutiny is fixed</h4>
                                <p class="muted">Difficulty, complexity, and grading strictness are pinned high. Personalities change delivery and voice, but not the bar.</p>
                                <div class="pill-row" style="margin-top:10px;">
                                    <span class="pill">Difficulty: max</span>
                                    <span class="pill">Complexity: max</span>
                                    <span class="pill">Grading: harsh</span>
                                </div>
                            </div>

                        </div>
                    </div>

                    <div class="setup-column">
                        <div id="persona-mode-block" class="setup-card">
                            <div class="setup-card__head">
                                <div>
                                    <p class="eyebrow">Interviewer personality</p>
                                    <h4>Select your interviewer</h4>
                                </div>
                                <p class="muted">Voice and delivery change. Operating mode keeps the same hard bar.</p>
                            </div>
                            <div class="persona-card-grid">
                                <% (safeInterviewConfig?.personas || []).forEach(function(persona) { %>
                                    <div class="persona-card" data-persona-id="<%= persona.id %>">
                                        <div class="persona-card__head">
                                            <div>
                                                <h4><%= persona.label %></h4>
                                                <p class="muted"><%= persona.interviewerName %></p>
                                            </div>
                                            <span class="pill"><%= persona.voice %></span>
                                        </div>
                                        <p class="persona-card__copy"><%= persona.summary %></p>
                                        <div class="pill-row">
                                            <% (persona.chips || []).forEach(function(chip) { %>
                                                <span class="pill"><%= chip %></span>
                                            <% }); %>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                            <input type="hidden" id="ctx-persona" value="">
                        </div>
                            <div id="crazy-mode-block" class="setup-card hidden">
                                <div class="setup-card__head">
                                    <div>
                                        <p class="eyebrow">Crazy tuning</p>
                                        <h4>Adjust the chaos</h4>
                                </div>
                                <p class="muted">Unlocked only in crazy mode.</p>
                            </div>

                                <div id="custom-tone-block">
                                    <label for="ctx-custom-tone">Additional instructions</label>
                                    <textarea id="ctx-custom-tone" rows="2" maxlength="200" placeholder="E.g., &quot;Channel Sherlock Holmes&quot; or &quot;Sound like a pirate&quot;" disabled></textarea>
                                </div>

                                <div>
                                    <label for="ctx-voice">AI voice</label>
                                    <select id="ctx-voice">
                                        <% (safeInterviewConfig?.voiceOptions || []).forEach(function(voice) { %>
                                            <option value="<%= voice.id %>"><%= voice.label %></option>
                                        <% }); %>
                                    </select>
                                </div>

                                <div class="slider-stack">
                                    <label for="ctx-seriousness">Seriousness <span id="seriousness-val" class="slider-val"></span></label>
                                    <input type="range" id="ctx-seriousness" min="0" max="1" step="0.01" value="0.5">

                                <label for="ctx-style">Professionalism style <span id="style-val" class="slider-val"></span></label>
                                <input type="range" id="ctx-style" min="0" max="1" step="0.01" value="0.5">

                                <label for="ctx-difficulty">Difficulty <span id="difficulty-val" class="slider-val"></span></label>
                                <input type="range" id="ctx-difficulty" min="0" max="1" step="0.01" value="0.5">

                                <label for="ctx-complexity">Complexity <span id="complexity-val" class="slider-val"></span></label>
                                <input type="range" id="ctx-complexity" min="0" max="1" step="0.01" value="0.5">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="setup-card setup-card-span">
                    <div class="setup-card__head">
                        <div>
                            <p class="eyebrow">Resume source</p>
                            <h4>Select resume</h4>
                        </div>
                        <p class="muted">Used for interview context and grading.</p>
                    </div>
                    <div class="resume-card-grid resume-card-grid-wide">
                        <% (resumes || []).forEach(function(r) { %>
                          <div class="resume-card" data-resume-id="<%= r._id %>">
                            <div class="resume-card__top">
                              <h4><%= r.originalName %></h4>
                              <div class="score-ring profile-ring" style="--score:<%= typeof r.fitScore === 'number' ? (r.fitScore*3.6) + 'deg' : '0deg' %>; --ring-color:<%= r.ringColor || '#555' %>;">
                                <div class="score-ring__fill"></div>
                                <div class="score-ring__center"><%= typeof r.fitScore === 'number' ? r.fitScore : '-' %></div>
                              </div>
                            </div>
                            <p class="muted">Tap to select</p>
                          </div>
                        <% }); %>
                    </div>
                    <input type="hidden" id="ctx-resume" value="">
                </div>

                <div class="modal-footer">
                    <button type="submit" id="context-submit" class="btn-primary">Create new chat</button>
                </div>
            </form>
        </div>
    </div>

    <script type="module" src="/scripts/openai/index.js"></script>

</body>
</html>
