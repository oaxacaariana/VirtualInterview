<!DOCTYPE html>
<html>
<head>
    <title>Sign Up | Virtual Interview</title>
    <link rel="stylesheet" href="/styles/app.css">
    <style>
        body { overflow: hidden; }
    </style>
</head>
<body class="auth-page">

    <!-- background -->
    <div class="auth-bg">
        <div class="auth-planet"></div>
        <div class="auth-planet-glow"></div>
        <div class="auth-star auth-star--1"></div>
        <div class="auth-star auth-star--2"></div>
        <div class="auth-star auth-star--3"></div>
        <div class="auth-ambient"></div>
    </div>

    <!-- card -->
    <div class="auth-wrap">
        <div class="auth-card">
            <div class="auth-card__glow"></div>

            <a href="/" class="auth-logo">Virtual Interview</a>

            <div class="auth-card__head">
                <h1 class="auth-title">Create account</h1>
                <p class="auth-sub">Simple username and password to access all tools.</p>
            </div>

            <% if (typeof error !== 'undefined' && error) { %>
                <p class="auth-error"><%= error %></p>
            <% } %>

            <form action="/signup" method="POST" class="auth-form">
                <div class="auth-field">
                    <input type="text" name="username" placeholder="Username" required autocomplete="username">
                </div>

                <div class="auth-field">
                    <input type="text" name="name" placeholder="Name (optional)">
                </div>

                <div class="auth-field">
                    <input type="password" name="password" id="auth-pw" placeholder="Password" required autocomplete="new-password">
                    <button type="button" class="auth-show-btn" onclick="togglePw(this)">Show</button>
                </div>

                <button type="submit" class="auth-submit">Create Account</button>
            </form>

            <p class="auth-footer-link">Already have an account? <a href="/login">Sign in</a></p>
        </div>
    </div>

    <script>
        function togglePw(btn) {
            const input = document.getElementById('auth-pw');
            const isHidden = input.type === 'password';
            input.type = isHidden ? 'text' : 'password';
            btn.textContent = isHidden ? 'Hide' : 'Show';
        }
    </script>
</body>
</html>
