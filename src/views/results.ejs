<!DOCTYPE html>
<html>
<head>
    <title>Results | AI Interview Simulator</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0' x2='1' y1='0' y2='1'%3E%3Cstop stop-color='%233a7bfd'/%3E%3Cstop offset='1' stop-color='%236b5bff'/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect width='64' height='64' rx='14' fill='%230f0f10'/%3E%3Cpath d='M18 42l10-20 8 12 10-8' stroke='url(%23g)' stroke-width='5' fill='none' stroke-linecap='round' stroke-linejoin='round'/%3E%3Ccircle cx='48' cy='18' r='4' fill='%236b5bff'/%3E%3C/svg%3E">
    <link rel="stylesheet" href="/stylesheets/styles.css">
</head>
<body>

<%- include('partials/navbar'); %>

<section class="results-section">
    <h1>Role Fit Assessment</h1>
    <div class="results-hero">
        <div>
            <p class="eyebrow">LLM-only scoring</p>
            <p class="muted">Based on your uploaded resume and job description.</p>
        </div>
        <img class="accent-illu sm" alt="Score illustration" src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 200'%3E%3Cdefs%3E%3ClinearGradient id='r' x1='0' x2='1' y1='0' y2='1'%3E%3Cstop stop-color='%2325f3ce'/%3E%3Cstop offset='1' stop-color='%236b5bff'/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect width='200' height='200' rx='28' fill='%23111114'/%3E%3Ccircle cx='94' cy='106' r='58' stroke='url(%23r)' stroke-width='10' fill='none' opacity='.9'/%3E%3Cpath d='M74 108l16 16 38-44' stroke='%23f0a202' stroke-width='10' fill='none' stroke-linecap='round' stroke-linejoin='round'/%3E%3Ccircle cx='140' cy='60' r='10' fill='%23f65fb1'/%3E%3C/svg%3E">
    </div>

    <div class="score-card">
        <h2>Fit Score</h2>
        <div class="score-ring results-ring" style="--score:<%= typeof fitScore === 'number' ? (fitScore*3.6) + 'deg' : '0deg' %>; --ring-color:<%= ringColor %>; width:160px; height:160px;">
            <div class="score-ring__fill"></div>
            <div class="score-ring__center" style="font-size:1.4rem;"><%= typeof fitScore === 'number' ? fitScore : '–' %></div>
        </div>
        <p class="muted" style="margin-top:12px;">
            Based on your resume (<%= resumeName %>) and the job description<% if (company) { %> at <%= company %><% } %>.
        </p>
    </div>

    <div class="feedback-grid">

        <div class="feedback-card">
            <h3>Strengths</h3>
            <% if (positives && positives.length) { %>
                <ul>
                    <% positives.forEach(item => { %>
                        <li><%= item %></li>
                    <% }) %>
                </ul>
            <% } else { %>
                <p class="muted">No positive signals captured yet.</p>
            <% } %>
        </div>

        <div class="feedback-card">
            <h3>Risks / Gaps</h3>
            <% if (negatives && negatives.length) { %>
                <ul>
                    <% negatives.forEach(item => { %>
                        <li><%= item %></li>
                    <% }) %>
                </ul>
            <% } else { %>
                <p class="muted">No risks identified.</p>
            <% } %>
        </div>

        <div class="feedback-card">
            <h3>Summary</h3>
            <p><%= summary || 'LLM summary unavailable.' %></p>
        </div>

        <div class="feedback-card">
            <h3>Job & Resume</h3>
            <p><strong>Job description:</strong> <%= jobSnippet || 'Not provided' %></p>
            <p><strong>Resume:</strong> <%= resumeName %> (<%= resumeSizeKb ? resumeSizeKb + ' KB' : 'size n/a' %>)</p>
            <% if (resumeId) { %>
                <p><strong>Resume ID:</strong> <%= resumeId %></p>
                <div style="margin-top:10px;">
                    <a class="btn-outline" href="/upload/preview/<%= resumeId %>" target="_blank">View Resume</a>
                </div>
            <% } %>
        </div>

    </div>

    <div class="center">
        <a href="/upload" class="btn-primary">Try Another Interview</a>
    </div>

</section>

<%- include('partials/footer'); %>

</body>
</html>
