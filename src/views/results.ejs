<!DOCTYPE html>
<html>
<head>
    <title>Results | AI Interview Simulator</title>
    <link rel="stylesheet" href="/stylesheets/styles.css">
</head>
<body>

<%- include('partials/navbar'); %>

<section class="results-section">
    <h1>Role Fit Assessment</h1>

    <div class="score-card">
        <h2>Fit Score</h2>
        <div class="score-ring results-ring" style="--score:<%= typeof fitScore === 'number' ? (fitScore*3.6) + 'deg' : '0deg' %>; --ring-color:<%= ringColor %>; width:160px; height:160px;">
            <div class="score-ring__fill"></div>
            <div class="score-ring__center" style="font-size:1.4rem;"><%= typeof fitScore === 'number' ? fitScore : '–' %></div>
        </div>
        <p class="muted">
            Based on your resume (<%= resumeName %>) and the job description<% if (company) { %> at <%= company %><% } %>.
        </p>
    </div>

    <div class="feedback-grid">

        <div class="feedback-card">
            <h3>Strengths</h3>
            <% if (positives && positives.length) { %>
                <ul>
                    <% positives.forEach(item => { %>
                        <li><%= item %></li>
                    <% }) %>
                </ul>
            <% } else { %>
                <p class="muted">No positive signals captured yet.</p>
            <% } %>
        </div>

        <div class="feedback-card">
            <h3>Risks / Gaps</h3>
            <% if (negatives && negatives.length) { %>
                <ul>
                    <% negatives.forEach(item => { %>
                        <li><%= item %></li>
                    <% }) %>
                </ul>
            <% } else { %>
                <p class="muted">No risks identified.</p>
            <% } %>
        </div>

        <div class="feedback-card">
            <h3>Summary</h3>
            <p><%= summary || 'LLM summary unavailable.' %></p>
        </div>

        <div class="feedback-card">
            <h3>Job & Resume</h3>
            <p><strong>Job description:</strong> <%= jobSnippet || 'Not provided' %></p>
            <p><strong>Resume:</strong> <%= resumeName %> (<%= resumeSizeKb ? resumeSizeKb + ' KB' : 'size n/a' %>)</p>
            <% if (resumeId) { %>
                <p><strong>Resume ID:</strong> <%= resumeId %></p>
                <div style="margin-top:10px;">
                    <a class="btn-outline" href="/upload/preview/<%= resumeId %>" target="_blank">View Resume</a>
                </div>
            <% } %>
        </div>

    </div>

    <div class="center">
        <a href="/upload" class="btn-primary">Try Another Interview</a>
    </div>

</section>

</body>
</html>
