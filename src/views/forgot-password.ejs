<!DOCTYPE html>
<html>
<head>
    <title>Forgot Password | Virtual Interview</title>
    <link rel="stylesheet" href="/styles/app.css">
</head>
<body>
    <nav class="navbar">
        <div class="logo">Virtual Interview Simulator</div>
        <div class="nav-links">
            <a href="/" class="btn-outline">Home</a>
            <a href="/login" class="btn-outline">Login</a>
            <a href="/signup" class="btn-primary">Sign Up</a>
        </div>
    </nav>

    <section class="form-section">
        <div class="form-container">
            <h1>Forgot password</h1>
            <p class="form-subtext">Enter your username to generate a one-time temporary password.</p>
            <% if (error) { %>
                <p class="form-message form-message--error"><%= error %></p>
            <% } %>
            <% if (temporaryPassword) { %>
                <div class="temp-password-card">
                    <p class="temp-password-card__label">Temporary one-time password for <strong><%= username %></strong></p>
                    <p class="temp-password-card__value"><%= temporaryPassword %></p>
                    <p class="temp-password-card__note">Use it to sign in once, then change your password on your profile page right away.</p>
                </div>
            <% } %>
            <form action="/forgot-password" method="POST">
                <label>Username</label>
                <input type="text" name="username" value="<%= username || '' %>" required>

                <button type="submit" class="btn-primary full-width">Generate Temporary Password</button>
            </form>
        </div>
    </section>
</body>
</html>
