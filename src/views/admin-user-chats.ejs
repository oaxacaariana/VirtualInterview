<!DOCTYPE html>
<html>
<head>
    <title>Admin User Chat Logs | Virtual Interview</title>
    <link rel="stylesheet" href="/styles/app.css">
</head>
<body>
    <%- include('partials/navbar'); %>
    <%
        const normalizeInterviewGrade = (storedGrade, score, reviewedTurns = 0) => {
            const normalizedStored = (storedGrade || '').toString().trim().toUpperCase();
            const reviewedTurnCount = Number(reviewedTurns);
            if (normalizedStored === 'P' || normalizedStored === 'DNF') return 'DNF';
            if (Number.isFinite(reviewedTurnCount) && reviewedTurnCount > 0 && reviewedTurnCount < 4) return 'DNF';
            if (['A', 'B', 'C', 'D', 'F'].includes(normalizedStored)) return normalizedStored;
            const numericScore = Number(score);
            if (!Number.isFinite(numericScore)) return 'DNF';
            if (numericScore >= 85) return 'A';
            if (numericScore >= 70) return 'B';
            if (numericScore >= 50) return 'C';
            if (numericScore >= 35) return 'D';
            return 'F';
        };
        const interviewGradeClass = (grade) => {
            if (grade === 'A') return 'grade-a';
            if (grade === 'B') return 'grade-b';
            if (grade === 'C') return 'grade-c';
            if (grade === 'D') return 'grade-d';
            if (grade === 'F') return 'grade-f';
            return 'grade-pending';
        };
        const ringColorForGrade = (grade) => {
            if (grade === 'A') return '#2dd4bf';
            if (grade === 'B') return '#60a5fa';
            if (grade === 'C') return '#f0a202';
            if (grade === 'D') return '#fb923c';
            if (grade === 'F') return '#f65f5f';
            return '#94a3b8';
        };
    %>

    <section class="results-section" style="text-align:left;">
        <div class="results-hero" style="align-items:flex-start;">
            <div>
                <p class="eyebrow">Admin transcript access</p>
                <h1 style="margin:2px 0 6px;"><%= targetUser.name || targetUser.username %></h1>
                <p class="muted">@<%= targetUser.username %> - <%= showDnf ? 'DNF interview archive.' : 'saved graded interview transcripts and final reviews.' %></p>
            </div>
            <div class="pill-row">
                <a href="/admin/users/<%= targetUser._id %>" class="btn-outline">Back to user</a>
                <% if (showDnf) { %>
                    <a href="/admin/users/<%= targetUser._id %>/chats" class="btn-outline">Back to graded</a>
                <% } else { %>
                    <a href="/admin/users/<%= targetUser._id %>/chats?dnf=1" class="btn-outline">View DNF</a>
                <% } %>
            </div>
        </div>

        <% if (chats && chats.length) { %>
            <div class="resumes-grid chat-logs-grid">
                <% chats.forEach(chat => { %>
                    <%
                        const rawRoleTitle = chat.context?.role || 'Interview';
                        const displayRoleTitle = rawRoleTitle.length > 44
                          ? `${rawRoleTitle.slice(0, 41)}...`
                          : rawRoleTitle;
                        const rawScore = chat.finalScore?.overallScore;
                        const score = Number.isFinite(Number(rawScore)) ? Number(rawScore) : null;
                        const gradeLetter = normalizeInterviewGrade(chat.finalScore?.grade, score, chat.finalScore?.reviewedTurns);
                        const gradeClass = interviewGradeClass(gradeLetter);
                        const gradeIsWide = gradeLetter.length > 1;
                        const ringScore = score !== null ? (score * 3.6) + 'deg' : '0deg';
                        const ringColor = ringColorForGrade(gradeLetter);
                    %>
                    <a href="/admin/users/<%= targetUser._id %>/chats/<%= chat.chatId %>" class="resume-card glass chat-log-card-link chat-grade-card <%= gradeClass %>">
                        <div class="resume-card__top">
                            <div class="resume-card__meta">
                                <h3 class="resume-title" title="<%= rawRoleTitle %>"><%= displayRoleTitle %></h3>
                                <p class="muted" style="margin-top:4px;">Company: <%= chat.context?.company || 'Not set' %></p>
                                <div class="pill-row" style="margin-top:10px;">
                                    <span class="pill">Status: <%= chat.status || 'unknown' %></span>
                                    <span class="pill">Updated: <%= chat.updatedAt ? new Date(chat.updatedAt).toISOString().slice(0,16).replace('T',' ') : 'n/a' %></span>
                                    <span class="pill">Length: <%= chat.interviewLength || 'n/a' %></span>
                                    <span class="pill">Mode: <%= chat.context?.modeLabel || (chat.context?.silly ? 'Crazy Mode' : 'Operating Mode') %></span>
                                    <span class="pill">Persona: <%= chat.context?.personaLabel || 'Legacy interviewer' %></span>
                                </div>
                            </div>
                            <div class="chat-grade-card__scorebox">
                                <div class="chat-grade-card__letter-label">GRADE</div>
                                <div class="score-ring score-ring--open-center profile-ring score-ring-lg chat-grade-ring" style="--score:<%= ringScore %>; --ring-color:<%= ringColor %>; flex-shrink:0;">
                                    <div class="score-ring__fill"></div>
                                    <div class="score-ring__center">
                                        <div class="chat-grade-card__letter <%= gradeIsWide ? 'chat-grade-card__letter--wide' : '' %>"><%= gradeLetter %></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                <% }) %>
            </div>
        <% } else { %>
            <p class="muted" style="text-align:center; margin-top:30px;"><%= showDnf ? 'No DNF chats found for this user.' : 'No graded chat logs found for this user.' %></p>
        <% } %>
    </section>

    <%- include('partials/footer'); %>
</body>
</html>
