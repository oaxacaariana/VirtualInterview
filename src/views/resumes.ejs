<!DOCTYPE html>
<html>
<head>
    <title>Resumes | Virtual Interview</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0' x2='1' y1='0' y2='1'%3E%3Cstop stop-color='%233a7bfd'/%3E%3Cstop offset='1' stop-color='%236b5bff'/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect width='64' height='64' rx='14' fill='%230f0f10'/%3E%3Cpath d='M18 42l10-20 8 12 10-8' stroke='url(%23g)' stroke-width='5' fill='none' stroke-linecap='round' stroke-linejoin='round'/%3E%3Ccircle cx='48' cy='18' r='4' fill='%236b5bff'/%3E%3C/svg%3E">
    <link rel="stylesheet" href="/styles/app.css">
</head>
<body>
<%- include('partials/navbar'); %>

<div class="pg-hero">
    <div class="pg-orb pg-orb--blue"></div>
    <div class="section-shell pg-hero__inner">
        <div>
            <p class="eyebrow">Your resume vault</p>
            <h1 class="pg-hero__title">Uploads &amp; fit scores</h1>
            <p class="pg-hero__sub">Condensed scoring metrics from every upload. Jump back into the full breakdown any time.</p>
        </div>
        <div class="hero-cta-row">
            <a href="/upload" class="btn-primary lp-btn-glow">Upload new resume</a>
            <a href="/openai" class="btn-outline lp-btn-outline">Start mock interview</a>
            <% if (showArchived) { %>
                <a href="/resumes" class="btn-outline lp-btn-outline">Back to active</a>
            <% } else { %>
                <a href="/resumes?archived=1" class="btn-outline lp-btn-outline">View archived</a>
            <% } %>
        </div>
    </div>
</div>

<section class="pg-body">
    <div class="section-shell">
        <% if (resumes && resumes.length) { %>
            <div class="resumes-grid">
                <% resumes.forEach((r) => {
                    const score = typeof r.fitScore === 'number' ? r.fitScore : null;
                    const ringScore = score !== null ? (score * 3.6) + 'deg' : '0deg';
                    const breakdown = r.fitRubric || {};
                    const nameLimit = 35;
                    const displayName = r.originalName
                        ? (r.originalName.length > nameLimit ? r.originalName.slice(0, nameLimit - 3) + '...' : r.originalName)
                        : 'Untitled resume';
                    const bars = (r.scoreRubricConfig || []).slice(0, 5).map((row) => ({
                        label: row.shortLabel,
                        val: breakdown[row.key],
                        max: row.max,
                    }));
                    const pct = (v, m) => (typeof v === 'number' && m ? Math.max(0, Math.min(100, Math.round((v / m) * 100))) : 0);
                    const strengthLabel = (v, m) => {
                        if (typeof v !== 'number' || !m) return 'Not rated';
                        const ratio = v / m;
                        if (ratio >= 0.85) return 'Excellent';
                        if (ratio >= 0.65) return 'Strong';
                        if (ratio >= 0.45) return 'Moderate';
                        if (ratio >= 0.25) return 'Limited';
                        return 'Weak';
                    };
                %>
                <div class="resume-card glass">
                    <div class="resume-card__top">
                        <div class="resume-card__meta">
                            <h3 class="resume-title" title="<%= r.originalName %>"><%= displayName %></h3>
                            <p class="muted" style="margin:2px 0 0; font-size:0.9rem;">
                                <%= r.fitTitle || 'Resume Strength & Role Fit' %> &bull; <%= r.fitLabel %>
                            </p>
                            <div class="pill-row" style="margin-top:6px;">
                                <span class="pill">Uploaded: <%= r.uploadedAt ? r.uploadedAt.toISOString().slice(0,10) : 'n/a' %></span>
                                <span class="pill">Size: <%= r.size ? Math.round(r.size/1024) + ' KB' : 'n/a' %></span>
                                <% if (r.fitCompany) { %><span class="pill">Company: <%= r.fitCompany %></span><% } %>
                            </div>
                        </div>
                        <div class="score-ring profile-ring score-ring-lg" style="--score:<%= ringScore %>; --ring-color:<%= r.ringColor %>; flex-shrink:0;">
                            <div class="score-ring__fill"></div>
                            <div class="score-ring__center score-ring__center--label"><%= r.fitBadge %></div>
                        </div>
                    </div>

                    <div class="bar-mini-grid" style="margin-top:14px;">
                        <% bars.forEach((row) => { %>
                            <div class="bar-mini">
                                <div class="bar-mini__label"><%= row.label %></div>
                                <div class="bar-mini__track">
                                    <div class="bar-mini__fill" style="--fill:<%= pct(row.val, row.max) %>%; --bar-color:<%= r.ringColor %>"></div>
                                </div>
                                <div class="bar-mini__value"><%= strengthLabel(row.val, row.max) %></div>
                            </div>
                        <% }) %>
                    </div>

                    <% if (r.fitSummary) { %>
                        <p class="muted" style="margin:8px 0 0;"><strong>Summary:</strong> <%= r.fitSummary %></p>
                    <% } %>

                    <div class="resume-card__actions">
                        <a href="/results?resumeId=<%= r._id %>" class="btn-outline">View full score</a>
                        <a href="/upload/preview/<%= r._id %>" class="btn-outline" target="_blank">Preview text</a>
                        <% if (showArchived) { %>
                            <form action="/resumes/<%= r._id %>/unarchive" method="POST" class="pill-action">
                                <button class="pill-btn pill-btn-primary" type="submit">Unarchive</button>
                            </form>
                        <% } else { %>
                            <form action="/resumes/<%= r._id %>/archive" method="POST" class="pill-action">
                                <button class="pill-btn" type="submit">Archive</button>
                            </form>
                        <% } %>
                    </div>
                </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="pg-empty">
                <p class="eyebrow">Nothing here yet</p>
                <h3>No resumes uploaded</h3>
                <p>Upload a resume and paste a job description to get your first score.</p>
                <a href="/upload" class="btn-primary lp-btn-glow">Upload resume</a>
            </div>
        <% } %>
    </div>
</section>

<%- include('partials/footer'); %>
</body>
</html>
