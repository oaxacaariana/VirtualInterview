<!DOCTYPE html>
<html>
<head>
    <title>AI Interview Simulator</title>
    <link rel="stylesheet" href="/stylesheets/styles.css">
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="logo">Virtual Interview Simulator</div>
        <div class="nav-links">
            <a href="/upload" class="btn-outline">Get Started</a>
        </div>
    </nav>

    <!-- HERO PART-->
    <section class="hero">
        <div class="hero-content">
            <h1>Your Personal Hiring Manager</h1>
            <p>
                This AI-powered interview preparation program simulates a “realistic” job interview 
                tailored to YOUR specific circumstances, giving you personalized feedback to boost your 
                confidence and performance.
            </p>
            <a href="/upload" class="btn-primary">Start Your Mock Interview Now</a>
        </div>
    </section>

    <!-- FEATURES -->
    <section class="features">
        <h2>Features</h2>

        <div class="feature-grid">
            <div class="feature-card">
                <h3>Tailored Questions</h3>
                <p>Questions generated from your resume, job description, and target company.</p>
            </div>

            <div class="feature-card">
                <h3>Virtual Simulation</h3>
                <p>Interactive mock interviews that feel like real conversations.</p>
            </div>

            <div class="feature-card">
                <h3>Performance Analysis</h3>
                <p>Feedback on speech clarity, eye contact, and overall delivery.</p>
            </div>

            <div class="feature-card">
                <h3>Personalized Feedback</h3>
                <p>Suggestions to improve confidence and interview performance.</p>
            </div>
        </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="how-it-works">
        <h2>How It Works</h2>

        <div class="steps">
            <div class="step">
                <span>1</span>
                <p>Upload your resume as a PDF and paste your job description.</p>
            </div>

            <div class="step">
                <span>2</span>
                <p>Start your personalized mock interview.</p>
            </div>

            <div class="step">
                <span>3</span>
                <p>Receive detailed feedback and improvement Suggestions.</p>
            </div>
        </div>
    </section>

    <!-- FOOTER 1 SECTION -->
    <section class="footer1">
        <h2>Develo your professional skills</h2>
        <p>Practice in a low-pressure environment before the real interview.</p>
        <a href="/upload" class="btn-primary">Upload Resume & Begin</a>
    </section>

    <footer>
        <p>https://github.com/oaxacaariana/VirtualInterview</p>
    </footer>

</body>
</html>