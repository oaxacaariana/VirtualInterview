<!DOCTYPE html>
<html>
<head>
    <title>Manage User | Virtual Interview</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0' x2='1' y1='0' y2='1'%3E%3Cstop stop-color='%233a7bfd'/%3E%3Cstop offset='1' stop-color='%236b5bff'/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect width='64' height='64' rx='14' fill='%230f0f10'/%3E%3Cpath d='M18 42l10-20 8 12 10-8' stroke='url(%23g)' stroke-width='5' fill='none' stroke-linecap='round' stroke-linejoin='round'/%3E%3Ccircle cx='48' cy='18' r='4' fill='%236b5bff'/%3E%3C/svg%3E">
    <link rel="stylesheet" href="/styles/app.css">
</head>
<body>
    <%- include('partials/navbar'); %>

    <section class="form-section admin-page">
        <div class="section-shell admin-detail-shell">
            <div class="glass admin-page__header">
                <div>
                    <p class="eyebrow">Admin panel</p>
                    <h1><%= user ? `Manage ${user.name || user.username}` : 'Manage user' %></h1>
                    <p class="form-subtext">Edit account identity, role, or password for this user.</p>
                </div>
                <a href="/admin/users" class="btn-outline">Back to users</a>
            </div>

            <% if (error) { %><p class="admin-message admin-message--error"><%= error %></p><% } %>
            <% if (success) { %><p class="admin-message admin-message--success"><%= success %></p><% } %>

            <% if (user) { %>
                <div class="admin-detail-grid">
                    <div class="glass admin-account-summary">
                        <p class="eyebrow">Account snapshot</p>
                        <h3><%= user.name || user.username %></h3>
                        <p class="muted">@<%= user.username %></p>
                        <div class="pill-row">
                            <a href="/admin/users/<%= user._id %>/resumes" class="btn-outline">View resumes</a>
                            <a href="/admin/users/<%= user._id %>/chats" class="btn-outline">View chat logs</a>
                        </div>
                        <dl class="admin-stat-grid">
                            <div><dt>Role</dt><dd><%= user.role || 'candidate' %></dd></div>
                            <div><dt>Resumes</dt><dd><%= userStats.resumeCount %></dd></div>
                            <div><dt>Resume Scores</dt><dd><%= userStats.resumeScoreCount %></dd></div>
                            <div><dt>Chats</dt><dd><%= userStats.chatCount %></dd></div>
                            <div><dt>Interview Scores</dt><dd><%= userStats.interviewScoreCount %></dd></div>
                            <div><dt>Created</dt><dd><%= user.createdAt ? new Date(user.createdAt).toLocaleDateString() : 'Unknown' %></dd></div>
                        </dl>
                    </div>

                    <div class="form-container admin-form-container">
                        <form action="/admin/users/<%= user._id %>" method="POST">
                            <label>Username</label>
                            <input type="text" name="username" value="<%= user.username || '' %>" required>

                            <label>Name</label>
                            <input type="text" name="name" value="<%= user.name || '' %>" required>

                            <label>Role</label>
                            <select name="role">
                                <% availableRoles.forEach((roleOption) => { %>
                                    <option value="<%= roleOption %>" <%= (user.role || 'candidate') === roleOption ? 'selected' : '' %>>
                                        <%= roleOption %>
                                    </option>
                                <% }) %>
                            </select>

                            <label>Reset Password</label>
                            <div class="password-field">
                                <input
                                    type="password"
                                    name="password"
                                    id="admin-password"
                                    placeholder="Leave blank to keep current password"
                                >
                                <button
                                    type="button"
                                    class="password-toggle"
                                    data-password-toggle
                                    data-target="admin-password"
                                    aria-controls="admin-password"
                                    aria-label="Show password"
                                >
                                    Show
                                </button>
                            </div>
                            <p class="muted" style="margin-top:8px;">Existing passwords are stored as secure hashes, so only a newly entered reset password can be shown here.</p>

                            <button type="submit" class="btn-primary full-width">Save user changes</button>
                        </form>
                    </div>
                </div>
            <% } %>
        </div>
    </section>

    <%- include('partials/footer'); %>
    <script>
        document.querySelectorAll('[data-password-toggle]').forEach((toggle) => {
            toggle.addEventListener('click', () => {
                const target = document.getElementById(toggle.dataset.target);
                if (!target) return;

                const showing = target.type === 'text';
                target.type = showing ? 'password' : 'text';
                toggle.textContent = showing ? 'Show' : 'Hide';
                toggle.setAttribute('aria-label', showing ? 'Show password' : 'Hide password');
            });
        });
    </script>
</body>
</html>
